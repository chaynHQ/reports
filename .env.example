# Copy this file to .env.local and fill in the values.
# If you're a Chayn volunteer, ask the team for access to the shared environment variables.

# ── Site ────────────────────────────────────────────────────────────────────
# Canonical URL used for Open Graph and sitemap generation.
# Defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL=https://your-site-url.com

# ── Rollbar (error logging) ─────────────────────────────────────────────────
# Create a project at https://rollbar.com and copy the two access tokens.
# The server token must never be exposed to the browser — keep it server-side only.
ROLLBAR_SERVER_TOKEN=your_server_token_here
NEXT_PUBLIC_ROLLBAR_CLIENT_TOKEN=your_client_token_here

# ── Google Analytics 4 ──────────────────────────────────────────────────────
# Measurement ID from your GA4 property (format: G-XXXXXXXXXX).
# Only loaded after explicit cookie consent.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Hotjar ──────────────────────────────────────────────────────────────────
# Site ID and snippet version from your Hotjar account.
# Only initialised after explicit cookie consent. Leave blank to disable.
NEXT_PUBLIC_HOTJAR_ID=
NEXT_PUBLIC_HOTJAR_SV=6

# ── Cypress Cloud (optional) ─────────────────────────────────────────────────
# Required only for recording test runs to Cypress Cloud.
# Create a project at https://cloud.cypress.io to obtain these values.
# CYPRESS_RECORD_KEY is sensitive — do not commit the real value.
CYPRESS_PROJECT_ID=your_project_id_here
CYPRESS_RECORD_KEY=your_record_key_here
